{% extends "layouts/base.django" %}
{% block content %}
<h1>git.shi.foo</h1>
{% if User %}
<p>Welcome back, <span class="text-purple">{{ User.Login }}</span>.</p>
{% else %}
<p>A self-hosted git front-end and push-proxy over GitHub. <a href="{% url "auth.login" %}">Log in with GitHub</a> to get started.</p>
{% endif %}
{% endblock %}