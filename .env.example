# Copy to .env and fill the GitHub values to enable login.
# The app boots and serves the (public) home page with placeholders;
# real GitHub OAuth App + GitHub App credentials are needed to log in.

# Server
HOST=0.0.0.0
PORT=3333
DEBUG=true

# Database (matches docker-compose.yml)
DSN=host=localhost user=postgres password=postgres dbname=gitshifoo port=5432 sslmode=disable

# Session
SESSION_COOKIE_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

# GitHub OAuth App + GitHub App
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
GITHUB_CALLBACK_URL=http://localhost:3333/auth/callback
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_INSTALLATION_ID=
GITHUB_ENCRYPTION_KEY=replace-me-with-a-long-random-string

# Git storage
REPOS_ROOT=.local/repos
SSH_ADDRESS=:2222